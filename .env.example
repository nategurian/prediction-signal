# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password (Settings → Database) — for scripts/deploy-cron.mjs only; never expose client-side.
# SUPABASE_DB_PASSWORD=your-database-password
# Or use full URI (any of these names work in scripts/deploy-cron.mjs):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.your-ref.supabase.co:5432/postgres
# POSTGRES_URL=...
#
# If direct db host is IPv6-only and deploy fails (EHOSTUNREACH), paste Session pooler URI from
# Supabase → Connect → Session pooler (includes correct AWS region):
# DATABASE_SESSION_POOLER_URL=postgresql://postgres.your-ref:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Kalshi
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY=your-rsa-private-key-pem-contents
KALSHI_DEMO=true

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Site URL (no trailing slash). Set on Vercel so run-pipeline can POST to /api/jobs/*.
# If unset, production uses VERCEL_URL automatically (see run-pipeline/route.ts).
NEXT_PUBLIC_SITE_URL=https://prediction-signal.vercel.app

# ETL/Cron Security (same value in Vercel + Supabase cron Bearer header)
ETL_CRON_SECRET=your-random-secret-token

# ─── Trading Bot webhook ─────────────────────────────────────────────────────
# Forwards `worth_trading` signals from `run-signals` to the external Kalshi
# trading bot (Documents/TradingBot/server.py). Leave TRADING_BOT_WEBHOOK_URL
# unset to disable forwarding entirely (paper-trading simulation continues).
#
# TRADING_BOT_WEBHOOK_URL — full URL incl. /webhook, e.g. https://bot.example.com/webhook
# TRADING_BOT_WEBHOOK_SECRET — random 32+ byte hex; must match WEBHOOK_SECRET on bot
# TRADING_BOT_CONTRACTS — number of $1 contracts per trade. Default 1.
#   At a $50-$100 starting bankroll keep this at 1 (≈$0.30-$0.75 per entry,
#   ~30-100 stacked-position headroom). Raise only after you have ≥1 week of
#   clean live execution and your bankroll has grown. Note this intentionally
#   diverges from `fixedTradeQuantity = 10` used by the in-DB paper simulation.
# TRADING_BOT_WEBHOOK_URL=https://bot.example.com/webhook
# TRADING_BOT_WEBHOOK_SECRET=
# TRADING_BOT_CONTRACTS=1
